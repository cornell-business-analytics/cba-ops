# Database
DATABASE_URL=postgresql+asyncpg://cba:cba_dev@localhost:5432/cba_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT — generate with: openssl genrsa -out private.pem 2048
# then: openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_DAYS=30

# ISR revalidation (shared secret with apps/website)
REVALIDATE_SECRET=change-me-in-production
WEBSITE_URL=http://localhost:3001

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Sentry (optional in dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# OpenTelemetry (Jaeger runs locally via docker compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
